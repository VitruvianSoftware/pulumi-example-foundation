// Example: infra_pipeline configuration for Cloud Build
// To enable, rename to example_infra_pipeline.go and add build tags.

package main

import (
	"fmt"

	"github.com/pulumi/pulumi-gcp/sdk/v9/go/gcp/projects"
	"github.com/pulumi/pulumi-gcp/sdk/v9/go/gcp/serviceaccount"
	"github.com/pulumi/pulumi-gcp/sdk/v9/go/gcp/sourcerepo"
	"github.com/pulumi/pulumi-gcp/sdk/v9/go/gcp/storage"
	"github.com/pulumi/pulumi/sdk/v3/go/pulumi"
	"github.com/pulumi/pulumi/sdk/v3/go/pulumi/config"
	"github.com/VitruvianSoftware/pulumi-library/go/pkg/project"
)

// DeployInfraPipeline creates the app-infra pipeline project and Cloud Build setup.
func DeployInfraPipeline(ctx *pulumi.Context) (map[string]pulumi.Output, error) {
	cfg := config.New(ctx, "")
	
	bootstrapRef, err := pulumi.NewStackReference(ctx, "bootstrap", nil)
	if err != nil {
		return nil, err
	}

	cloudbuildProjectId := bootstrapRef.GetOutput(pulumi.String("cloudbuild_project_id")).ApplyT(func(v interface{}) string {
		return v.(string)
	}).(pulumi.StringOutput)

	defaultRegion := cfg.Require("default_region")
	projectPrefix := cfg.Get("project_prefix")
	if projectPrefix == "" {
		projectPrefix = "prj"
	}
	businessCode := cfg.Get("business_code")
	if businessCode == "" {
		businessCode = "bu1"
	}
	orgId := cfg.Require("org_id")
	billingAccount := cfg.Require("billing_account")

	// App-infra Cloud Build project
	appInfraProject, err := project.NewProjectFactory(ctx, "app-infra-pipeline", &project.ProjectFactoryArgs{
		Name:           pulumi.String(fmt.Sprintf("%s-c-%s-infra-pipeline", projectPrefix, businessCode)),
		OrgId:          pulumi.String(orgId),
		BillingAccount: pulumi.String(billingAccount),
		FolderId:       pulumi.String(cfg.Require("common_folder_name")),
		DeletionPolicy: pulumi.String("PREVENT"),
		ActivateApis: pulumi.StringArray{
			pulumi.String("cloudbuild.googleapis.com"),
			pulumi.String("cloudresourcemanager.googleapis.com"),
			pulumi.String("iam.googleapis.com"),
			pulumi.String("billingbudgets.googleapis.com"),
			pulumi.String("artifactregistry.googleapis.com"),
		},
		Labels: pulumi.StringMap{
			"environment":      pulumi.String("common"),
			"application_name": pulumi.String(fmt.Sprintf("%s-infra-pipeline", businessCode)),
			"billing_code":     pulumi.String("1234"),
			"primary_contact":  pulumi.String("example1"),
			"secondary_contact": pulumi.String("example2"),
			"business_code":    pulumi.String(businessCode),
			"env_code":         pulumi.String("c"),
			"vpc":              pulumi.String("none"),
		},
	})
	if err != nil {
		return nil, err
	}

	tfCbBuilderSa, err := serviceaccount.NewAccount(ctx, "tf-cb-builder-sa", &serviceaccount.AccountArgs{
		AccountId: pulumi.String("tf-cb-builder-sa"),
		Project:   cloudbuildProjectId,
	})
	if err != nil {
		return nil, err
	}

	buildRoles := []string{
		"roles/storage.objectAdmin",
		"roles/cloudbuild.builds.builder",
	}

	for i, role := range buildRoles {
		_, err := projects.NewIAMMember(ctx, fmt.Sprintf("build-role-%d", i), &projects.IAMMemberArgs{
			Project: cloudbuildProjectId,
			Role:    pulumi.String(role),
			Member:  pulumi.Sprintf("serviceAccount:%s", tfCbBuilderSa.Email),
		})
		if err != nil {
			return nil, err
		}
	}

	repoName := "bu1-example-app"
	repo, err := sourcerepo.NewRepository(ctx, "app-infra-repo", &sourcerepo.RepositoryArgs{
		Name:    pulumi.String(repoName),
		Project: cloudbuildProjectId,
	})
	if err != nil {
		return nil, err
	}

	_, err = sourcerepo.NewRepository(ctx, "gcp-policies", &sourcerepo.RepositoryArgs{
		Name:    pulumi.String("gcp-policies"),
		Project: cloudbuildProjectId,
	})
	if err != nil {
		return nil, err
	}

	cloudbuildBucketName := pulumi.Sprintf("%s_cloudbuild", cloudbuildProjectId)
	_, err = storage.NewBucket(ctx, "cloudbuild-bucket", &storage.BucketArgs{
		Name:                     cloudbuildBucketName,
		Project:                  cloudbuildProjectId,
		Location:                 pulumi.String(defaultRegion),
		UniformBucketLevelAccess: pulumi.Bool(true),
		ForceDestroy:             pulumi.Bool(true),
		Versioning: &storage.BucketVersioningArgs{
			Enabled: pulumi.Bool(true),
		},
	})
	if err != nil {
		return nil, err
	}

	workspaceSa, err := serviceaccount.NewAccount(ctx, "sa-tf-cb-workspace", &serviceaccount.AccountArgs{
		AccountId: pulumi.String(fmt.Sprintf("sa-tf-cb-%s", repoName)),
		Project:   cloudbuildProjectId,
	})
	if err != nil {
		return nil, err
	}

	prefix := cfg.Get("bucket_prefix")
	if prefix == "" {
		prefix = "bkt"
	}

	stateBucket, err := storage.NewBucket(ctx, "state-bucket", &storage.BucketArgs{
		Name:                     pulumi.Sprintf("%s-%s-%s-state", prefix, cloudbuildProjectId, repoName),
		Project:                  cloudbuildProjectId,
		Location:                 pulumi.String(defaultRegion),
		UniformBucketLevelAccess: pulumi.Bool(true),
		ForceDestroy:             pulumi.Bool(true),
		Versioning: &storage.BucketVersioningArgs{
			Enabled: pulumi.Bool(true),
		},
	})
	if err != nil {
		return nil, err
	}

	logBucket, err := storage.NewBucket(ctx, "logs-bucket", &storage.BucketArgs{
		Name:                     pulumi.Sprintf("%s-%s-%s-logs", prefix, cloudbuildProjectId, repoName),
		Project:                  cloudbuildProjectId,
		Location:                 pulumi.String(defaultRegion),
		UniformBucketLevelAccess: pulumi.Bool(true),
		ForceDestroy:             pulumi.Bool(true),
	})
	if err != nil {
		return nil, err
	}

	artifactsBucket, err := storage.NewBucket(ctx, "artifacts-bucket", &storage.BucketArgs{
		Name:                     pulumi.Sprintf("%s-%s-%s-artifacts", prefix, cloudbuildProjectId, repoName),
		Project:                  cloudbuildProjectId,
		Location:                 pulumi.String(defaultRegion),
		UniformBucketLevelAccess: pulumi.Bool(true),
		ForceDestroy:             pulumi.Bool(true),
	})
	if err != nil {
		return nil, err
	}

	_, err = storage.NewBucketIAMMember(ctx, "cloudbuild-storage-read", &storage.BucketIAMMemberArgs{
		Bucket: logBucket.Name,
		Role:   pulumi.String("roles/storage.admin"),
		Member: pulumi.Sprintf("serviceAccount:%s", appInfraProject.ServiceAccountEmail),
	})
	if err != nil {
		return nil, err
	}

	_, err = storage.NewBucketIAMMember(ctx, "cloudbuild-sa-storage-admin", &storage.BucketIAMMemberArgs{
		Bucket: logBucket.Name,
		Role:   pulumi.String("roles/storage.admin"),
		Member: pulumi.Sprintf("serviceAccount:%s", tfCbBuilderSa.Email),
	})
	if err != nil {
		return nil, err
	}

	_, err = projects.NewIAMMember(ctx, "workload-identity-admin", &projects.IAMMemberArgs{
		Project: appInfraProject.ProjectId,
		Role:    pulumi.String("roles/iam.workloadIdentityPoolAdmin"),
		Member:  pulumi.Sprintf("serviceAccount:%s", appInfraProject.ServiceAccountEmail),
	})
	if err != nil {
		return nil, err
	}

	_, err = organizations.NewIAMMember(ctx, "org-browser-binding", &organizations.IAMMemberArgs{
		OrgId:  pulumi.String(orgId),
		Role:   pulumi.String("roles/browser"),
		Member: pulumi.Sprintf("serviceAccount:%s", workspaceSa.Email),
	})
	if err != nil {
		return nil, err
	}

	outputs := map[string]pulumi.Output{
		"app_infra_pipeline_project_id": appInfraProject.ProjectId.ToStringOutput(),
		"default_region":                pulumi.String(defaultRegion).ToStringOutput(),
		"cloudbuild_sa":                 workspaceSa.Email.ToStringOutput(),
		"cloudbuild_bucket":             cloudbuildBucketName.ToStringOutput(),
		"source_repos":                  repo.Name.ToStringOutput(),
		"log_buckets":                   logBucket.Name.ToStringOutput(),
		"state_buckets":                 stateBucket.Name.ToStringOutput(),
		"artifacts_buckets":             artifactsBucket.Name.ToStringOutput(),
	}

	return outputs, nil
}
