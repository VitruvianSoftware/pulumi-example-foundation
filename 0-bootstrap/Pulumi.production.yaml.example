# Pulumi Configuration for 0-bootstrap (production stack)
#
# Copy this file to Pulumi.production.yaml and fill in the values:
#   cp Pulumi.production.yaml.example Pulumi.production.yaml
#
# Or set values via CLI:
#   pulumi config set org_id "YOUR_ORG_ID"

config:
  # Required
  foundation:org_id: "YOUR_ORG_ID"
  foundation:billing_account: "XXXXXX-XXXXXX-XXXXXX"
  foundation:group_org_admins: "org-admins@example.com"
  foundation:group_billing_admins: "billing-admins@example.com"
  foundation:billing_data_users: "billing-data@example.com"
  foundation:audit_data_users: "audit-data@example.com"

  # Optional (defaults shown)
  # foundation:project_prefix: "prj"
  # foundation:folder_prefix: "fldr"
  # foundation:bucket_prefix: "bkt"
  # foundation:default_region: "us-central1"
  # foundation:default_region_2: "us-west1"
  # foundation:default_region_gcs: "US"
  # foundation:default_region_kms: "us"
  # foundation:parent_folder: ""
  # foundation:random_suffix: "true"
  # foundation:bucket_force_destroy: "false"

  # GitHub Actions CI/CD (set github_owner to enable WIF)
  # foundation:github_owner: "YOUR_GITHUB_ORG"
  # foundation:github_repo_bootstrap: "gcp-bootstrap"

  # Optional Groups
  # foundation:gcp_security_reviewer: ""
  # foundation:gcp_network_viewer: ""
  # foundation:gcp_scc_admin: ""
  # foundation:gcp_global_secrets_admin: ""
  # foundation:gcp_kms_admin: ""
